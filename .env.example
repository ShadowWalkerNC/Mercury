# ─── Server ───────────────────────────────────────────────────────────────────
# Required. Hard-fail on startup if missing.
JWT_SECRET=change_me_to_a_long_random_string_at_least_64_chars
CONTROL_SECRET=change_me_to_another_long_random_string

# Optional — defaults shown
PORT=4000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173

# ─── Database ─────────────────────────────────────────────────────────────────
# Path to the SQLite database file. Directory is created automatically.
DB_PATH=./data/mercury.db

# ─── Web client (Vite) ────────────────────────────────────────────────────────
# Must match the server PORT above
VITE_API_URL=http://localhost:4000
VITE_WS_URL=ws://localhost:4000
