# Copy to .env and fill in values before running docker-compose up

# Postgres
POSTGRES_USER=mercury
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mercury

# API
JWT_SECRET=change_me_at_least_32_chars_long!!

# VAPID (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# S3 / object storage
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Vite (build-time)
VITE_API_BASE_URL=
VITE_VAPID_PUBLIC_KEY=
